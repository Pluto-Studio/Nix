Subject: [PATCH] Avoid Optional allocation on mob spawn hot path


diff --git a/net/minecraft/util/random/WeightedList.java b/net/minecraft/util/random/WeightedList.java
index a8481259e42aa116e29bccd1e30fdfd91f51a8cc..a910923b3650360cd138c4d6604f21fa24414620 100644
--- a/net/minecraft/util/random/WeightedList.java
+++ b/net/minecraft/util/random/WeightedList.java
@@ -82,6 +82,17 @@ public class WeightedList<E> { // Paper - non-final
         return Optional.of(this.selector.get(selection));
     }
 
+    // Nix start - Avoid Optional allocation on mob spawn hot path
+    public @Nullable E getRandomOrNull(final RandomSource random) {
+        if (this.selector == null) {
+            return null;
+        } else {
+            int selection = random.nextInt(this.totalWeight);
+            return Objects.requireNonNull(this.selector.get(selection));
+        }
+    }
+    // Nix end - Avoid Optional allocation on mob spawn hot path
+
     public E getRandomOrThrow(final RandomSource random) {
         if (this.selector == null) {
             throw new IllegalStateException("Weighted list has no elements");
