@@ -461,6 +463,22 @@ public final class NaturalSpawner {
             : mobsAt(level, structureManager, generator, mobCategory, pos, biome).getRandom(random);
     }
 
+    // Nix start - Avoid Optional allocation on mob spawn hot path
+    private static MobSpawnSettings.@Nullable SpawnerData getRandomSpawnMobAtOrNull(
+            final ServerLevel level,
+            final StructureManager structureManager,
+            final ChunkGenerator generator,
+            final MobCategory mobCategory,
+            final RandomSource random,
+            final BlockPos pos
+    ) {
+        Holder<Biome> biome = level.getBiome(pos);
+        return mobCategory == MobCategory.WATER_AMBIENT && biome.is(BiomeTags.REDUCED_WATER_AMBIENT_SPAWNS) && random.nextFloat() < 0.98F
+                ? null
+                : mobsAt(level, structureManager, generator, mobCategory, pos, biome).getRandomOrNull(random);
+    }
+    // Nix end - Avoid Optional allocation on mob spawn hot path
+
