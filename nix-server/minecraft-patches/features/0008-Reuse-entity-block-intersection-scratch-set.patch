From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: nostalfinals <yuu8583@proton.me>
Date: Sun, 26 Apr 2026 18:03:18 +0800
Subject: [PATCH] Reuse entity block intersection scratch set

Replace the traversal scratch set used by Entity#checkInsideBlocks with a LongArraySet.
Entity block-intersection traversal is capped at 16 movement iterations, so the scratch set usually remains small enough for linear lookup to be cheaper than initializing and probing a LongOpenHashSet.

diff --git a/net/minecraft/world/entity/Entity.java b/net/minecraft/world/entity/Entity.java
index 9cd46a8619e575a865f4d00ce71d249c9b028b2f..e2907205ecb01afcbf252923f89446ba22201080 100644
--- a/net/minecraft/world/entity/Entity.java
+++ b/net/minecraft/world/entity/Entity.java
@@ -353,6 +353,7 @@ public abstract class Entity
     private final ArrayDeque<Entity.Movement> movementThisTick = new ArrayDeque<>(100);
     private final List<Entity.Movement> finalMovementsThisTick = new ObjectArrayList<>();
     private final LongSet visitedBlocks = new LongOpenHashSet();
+    private final LongSet blockIntersectionScratch = new it.unimi.dsi.fastutil.longs.LongArraySet(); // Nix - Reuse entity block intersection scratch set
     private final InsideBlockEffectApplier.StepBasedCollector insideEffectCollector = new InsideBlockEffectApplier.StepBasedCollector();
     private CustomData customData = CustomData.EMPTY;
     // CraftBukkit start
@@ -1755,10 +1756,13 @@ public abstract class Entity
         boolean debugEntityBlockIntersections = this.level instanceof ServerLevel serverLevel
             && serverLevel.getServer().debugSubscribers().hasAnySubscriberFor(DebugSubscriptions.ENTITY_BLOCK_INTERSECTIONS);
         AtomicInteger iterations = new AtomicInteger();
-        BlockGetter.forEachBlockIntersectedBetween(
+        // Nix start - Reuse entity block intersection scratch set
+        BlockGetter.nix$forEachBlockIntersectedBetween(
             from,
             to,
             deflatedBoundingBoxAtTarget,
+            this.blockIntersectionScratch,
+            // Nix end - Reuse entity block intersection scratch set
             (blockIntersection, iteration) -> {
                 if (!this.isAlive()) {
                     return false;
