From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: nostalfinals <yuu8583@proton.me>
Date: Sun, 26 Apr 2026 18:03:18 +0800
Subject: [PATCH] Reuse entity block intersection scratch set

Replace the traversal scratch set used by Entity#checkInsideBlocks with a LongArraySet.
Entity block-intersection traversal is capped at 16 movement iterations, so the scratch set usually remains small enough for linear lookup to be cheaper than a LongOpenHashSet.

diff --git a/net/minecraft/world/entity/Entity.java b/net/minecraft/world/entity/Entity.java
index 1530810cdb74810e37e3e22ce4fcda4ee7511055..aa54becfdcdbf579b817d4c1e70479d7773172e9 100644
--- a/net/minecraft/world/entity/Entity.java
+++ b/net/minecraft/world/entity/Entity.java
@@ -354,6 +354,7 @@ public abstract class Entity
     private final ArrayDeque<Entity.Movement> movementThisTick = new ArrayDeque<>(100);
     private final List<Entity.Movement> finalMovementsThisTick = new ObjectArrayList<>();
     private final LongSet visitedBlocks = new LongOpenHashSet();
+    private final LongSet blockIntersectionScratch = new it.unimi.dsi.fastutil.longs.LongArraySet(); // Nix - Reuse entity block intersection scratch set
     private final InsideBlockEffectApplier.StepBasedCollector insideEffectCollector = new InsideBlockEffectApplier.StepBasedCollector();
     private CustomData customData = CustomData.EMPTY;
     // CraftBukkit start
@@ -1836,10 +1837,13 @@ public abstract class Entity
         boolean debugEntityBlockIntersections = this.level instanceof ServerLevel serverLevel
             && serverLevel.getServer().debugSubscribers().hasAnySubscriberFor(DebugSubscriptions.ENTITY_BLOCK_INTERSECTIONS);
         AtomicInteger iterations = new AtomicInteger();
-        BlockGetter.forEachBlockIntersectedBetween(
+        // Nix start - Reuse entity block intersection scratch set
+        BlockGetter.nix$forEachBlockIntersectedBetween(
             from,
             to,
             deflatedBoundingBoxAtTarget,
+            this.blockIntersectionScratch,
+            // Nix end - Reuse entity block intersection scratch set
             (blockIntersection, iteration) -> {
                 if (!this.isAlive()) {
                     return false;
diff --git a/net/minecraft/world/level/BlockGetter.java b/net/minecraft/world/level/BlockGetter.java
index 2a4c928281c7e455d6f210aeb599881855d328f8..e03710c5d9823facb584e24800af918a485500f5 100644
--- a/net/minecraft/world/level/BlockGetter.java
+++ b/net/minecraft/world/level/BlockGetter.java
@@ -217,30 +217,59 @@ public interface BlockGetter extends LevelHeightAccessor {
 
             return true;
         } else {
+            // Nix start - Reuse entity block intersection scratch set
             LongSet visitedBlocks = new LongOpenHashSet();
+            return forEachBlockIntersectedBetweenWithMove(travel, aabbAtTarget, visitedBlocks, visitor);
+            // Nix end - Reuse entity block intersection scratch set
+        }
+    }
 
-            for (BlockPos blockPos : BlockPos.betweenCornersInDirection(aabbAtTarget.move(travel.scale(-1.0)), travel)) {
+    // Nix start - Reuse entity block intersection scratch set
+    static boolean nix$forEachBlockIntersectedBetween(final Vec3 from, final Vec3 to, final AABB aabbAtTarget, final LongSet visitedBlocks, final BlockGetter.BlockStepVisitor visitor) {
+        Vec3 travel = to.subtract(from);
+        if (travel.lengthSqr() < Mth.square(1.0E-5F)) {
+            for (BlockPos blockPos : BlockPos.betweenClosed(aabbAtTarget)) {
                 if (!visitor.visit(blockPos, 0)) {
                     return false;
                 }
+            }
 
-                visitedBlocks.add(blockPos.asLong());
+            return true;
+        } else {
+            if (!visitedBlocks.isEmpty()) {
+                visitedBlocks.clear();
+            }
+            try {
+                return forEachBlockIntersectedBetweenWithMove(travel, aabbAtTarget, visitedBlocks, visitor);
+            } finally {
+                visitedBlocks.clear();
             }
+        }
+    }
 
-            int iterations = addCollisionsAlongTravel(visitedBlocks, travel, aabbAtTarget, visitor);
-            if (iterations < 0) {
+    private static boolean forEachBlockIntersectedBetweenWithMove(final Vec3 travel, final AABB aabbAtTarget, final LongSet visitedBlocks, final BlockGetter.BlockStepVisitor visitor) {
+        for (BlockPos blockPos : BlockPos.betweenCornersInDirection(aabbAtTarget.move(travel.scale(-1.0)), travel)) {
+            if (!visitor.visit(blockPos, 0)) {
                 return false;
             }
 
-            for (BlockPos blockPos : BlockPos.betweenCornersInDirection(aabbAtTarget, travel)) {
-                if (visitedBlocks.add(blockPos.asLong()) && !visitor.visit(blockPos, iterations + 1)) {
-                    return false;
-                }
-            }
+            visitedBlocks.add(blockPos.asLong());
+        }
 
-            return true;
+        int iterations = addCollisionsAlongTravel(visitedBlocks, travel, aabbAtTarget, visitor);
+        if (iterations < 0) {
+            return false;
         }
+
+        for (BlockPos blockPos : BlockPos.betweenCornersInDirection(aabbAtTarget, travel)) {
+            if (visitedBlocks.add(blockPos.asLong()) && !visitor.visit(blockPos, iterations + 1)) {
+                return false;
+            }
+        }
+
+        return true;
     }
+    // Nix end - Reuse entity block intersection scratch set
 
     private static int addCollisionsAlongTravel(
         final LongSet visitedBlocks, final Vec3 deltaMove, final AABB aabbAtTarget, final BlockGetter.BlockStepVisitor visitor
