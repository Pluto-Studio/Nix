From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: nostalfinals <yuu8583@proton.me>
Date: Wed, 22 Apr 2026 19:47:52 +0800
Subject: [PATCH] Avoid ChunkPos allocation in NaturalSpawner distance check


diff --git a/net/minecraft/server/level/ServerLevel.java b/net/minecraft/server/level/ServerLevel.java
index ca1725b9ad40f41e241447e14948ee4116c3e4c9..1d2d3dc37c846a92ed1fdff0a5f26853353ca27b 100644
--- a/net/minecraft/server/level/ServerLevel.java
+++ b/net/minecraft/server/level/ServerLevel.java
@@ -2718,6 +2718,23 @@ public class ServerLevel extends Level implements WorldGenLevel, ServerEntityGet
         // Paper end - rewrite chunk system
     }
 
+    // Nix start - Avoid ChunkPos allocation in NaturalSpawner distance check
+    public boolean nix$canSpawnEntitiesInChunk(final int chunkX, final int chunkZ) {
+        final ca.spottedleaf.moonrise.patches.chunk_system.scheduling.NewChunkHolder chunkHolder = this.moonrise$getChunkTaskScheduler().chunkHolderManager.getChunkHolder(ca.spottedleaf.moonrise.common.util.CoordinateUtils.getChunkKey(chunkX, chunkZ));
+        final WorldBorder worldBorder = this.getWorldBorder();
+
+        final int minBlockX = chunkX << 4;
+        final int minBlockZ = chunkZ << 4;
+        final int maxBlockX = minBlockX + 15;
+        final int maxBlockZ = minBlockZ + 15;
+
+        return chunkHolder != null
+                && chunkHolder.isEntityTickingReady()
+                && worldBorder.isWithinBounds(minBlockX, minBlockZ)
+                && worldBorder.isWithinBounds(maxBlockX, maxBlockZ);
+    }
+    // Nix end - Avoid ChunkPos allocation in NaturalSpawner distance check
+
     @Override
     public FeatureFlagSet enabledFeatures() {
         return this.server.getWorldData().enabledFeatures();
diff --git a/net/minecraft/world/level/NaturalSpawner.java b/net/minecraft/world/level/NaturalSpawner.java
index 00632cef96c4f64ad439565869df5d48719ac3a2..979727a20d6bfdcbfa72b2e66e37274869543e52 100644
--- a/net/minecraft/world/level/NaturalSpawner.java
+++ b/net/minecraft/world/level/NaturalSpawner.java
@@ -368,8 +368,12 @@ public final class NaturalSpawner {
             return false;
         }
 
-        ChunkPos chunkPos = ChunkPos.containing(pos);
-        return Objects.equals(chunkPos, chunk.getPos()) || level.canSpawnEntitiesInChunk(chunkPos);
+        // Nix start - Avoid ChunkPos allocation in NaturalSpawner distance check
+        final ChunkPos chunkPos = chunk.getPos();
+        final int chunkX = pos.getX() >> 4;
+        final int chunkZ = pos.getZ() >> 4;
+        return (chunkPos.x() == chunkX && chunkPos.z() == chunkZ) || level.nix$canSpawnEntitiesInChunk(chunkX, chunkZ);
+        // Nix end - Avoid ChunkPos allocation in NaturalSpawner distance check
     }
 
     // Paper start - PreCreatureSpawnEvent
